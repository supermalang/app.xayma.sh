{
  "name": "xayma-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host --port 5173 --strictPort",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "stop": "fuser -k 5173/tcp 2>/dev/null; vibe-annotations-server stop; echo '✅ All dev servers stopped'",
    "supabase:types": "npx supabase gen types typescript --linked -s xayma_app > src/types/supabase.ts",
    "supabase:push": "npx supabase db push --linked"
  },
  "dependencies": {
    "@primevue/themes": "^4.2.0",
    "@sentry/vue": "^10.40.0",
    "@supabase/supabase-js": "^2.39.0",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^14.2.1",
    "echarts": "^5.5.0",
    "pinia": "^2.1.7",
    "primeicons": "^7.0.0",
    "primevue": "^4.2.0",
    "vee-validate": "^4.13.0",
    "vue": "^3.4.0",
    "vue-echarts": "^7.0.0",
    "vue-i18n": "^11.2.8",
    "vue-router": "^4.2.5",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@anthropic-ai/claude-code": "latest",
    "@playwright/mcp": "latest",
    "@playwright/test": "^1.41.0",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/coverage-v8": "^3.0.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.17",
    "dotenv": "^17.3.1",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.3.3",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "vue-tsc": "^2.0.0"
  }
}
